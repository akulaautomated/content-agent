# ─── LLM PROVIDER ────────────────────────────────────────────
# Choose "openai" or "anthropic"
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# OpenAI API Key (get from https://platform.openai.com)
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic API Key (optional, only needed if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ─── DATABASE ────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=content_agent
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/content_agent

# ─── REDIS (used for caching agent results) ──────────────────
REDIS_URL=redis://redis:6379/0

# ─── SECURITY ────────────────────────────────────────────────
# Change this to a long random string in production!
JWT_SECRET=change-this-to-a-very-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ─── APP SETTINGS ────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:80
